using System;
using System.Linq;
using System.Windows;

namespace IS_GTS.Windows
{
    public partial class ChangePasswordWindow : Window
    {
        private int _userId;

        public ChangePasswordWindow(int userId)
        {
            InitializeComponent();
            _userId = userId;
        }

        private void ChangePassword_Click(object sender, RoutedEventArgs e)
        {
            string oldPassword = OldPasswordBox.Password;
            string newPassword = NewPasswordBox.Password;
            string confirmPassword = ConfirmPasswordBox.Password;

            if (string.IsNullOrEmpty(oldPassword))
            {
                ShowError("Введите старый пароль!");
                return;
            }

            if (string.IsNullOrEmpty(newPassword))
            {
                ShowError("Введите новый пароль!");
                return;
            }

            if (newPassword.Length < 4)
            {
                ShowError("Пароль должен содержать минимум 4 символа!");
                return;
            }

            if (newPassword != confirmPassword)
            {
                ShowError("Новый пароль и подтверждение не совпадают!");
                return;
            }

            using (var db = new Data.DiplomMurEntities())
            {
                var user = db.User.FirstOrDefault(u => u.UserID == _userId);

                if (user == null)
                {
                    ShowError("Пользователь не найден!");
                    return;
                }

                if (user.UserPassword != oldPassword)
                {
                    ShowError("Неверный старый пароль!");
                    return;
                }

                user.UserPassword = newPassword;
                db.SaveChanges();

                MessageBox.Show("Пароль успешно изменен!", "Успех",
                    MessageBoxButton.OK, MessageBoxImage.Information);
                Close();
            }
        }

        private void ShowError(string message)
        {
            ErrorText.Text = message;
            ErrorText.Visibility = Visibility.Visible;

            var timer = new System.Windows.Threading.DispatcherTimer();
            timer.Interval = TimeSpan.FromSeconds(3);
            timer.Tick += (s, e) =>
            {
                ErrorText.Visibility = Visibility.Collapsed;
                timer.Stop();
            };
            timer.Start();
        }

        private void Cancel_Click(object sender, RoutedEventArgs e)
        {
            Close();
        }
    }
}