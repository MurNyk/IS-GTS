        private void ExportStatsToExcel_Click(object sender, RoutedEventArgs e)
        {
            using (var package = new ExcelPackage())
            {
                var worksheet = package.Workbook.Worksheets.Add("Полная статистика");

                // Заголовок
                worksheet.Cells[1, 1].Value = "Полная статистика избранного (с разбивкой по категориям)";
                worksheet.Cells[1, 1].Style.Font.Bold = true;
                worksheet.Cells[1, 1].Style.Font.Size = 14;
                worksheet.Cells[2, 1].Value = $"Дата формирования: {DateTime.Now:dd.MM.yyyy HH:mm}";

                int currentRow = 4;

                // Получаем все категории с их профилями
                using (var db = new DiplomMurEntities())
                {
                    var categories = db.Favorite
                        .Include(f => f.Size)
                        .Include(f => f.Size.Product)
                        .Include(f => f.Size.Product.Category)
                        .Where(f => f.Size != null && f.Size.Product != null && f.Size.Product.Category != null)
                        .GroupBy(f => f.Size.Product.Category.CategoryName)
                        .Select(g => new { CategoryName = g.Key, TotalCount = g.Count() })
                        .OrderByDescending(c => c.TotalCount)
                        .ToList();

                    foreach (var category in categories)
                    {
                        // Заголовок категории
                        worksheet.Cells[currentRow, 1].Value = category.CategoryName;
                        worksheet.Cells[currentRow, 1].Style.Font.Bold = true;
                        worksheet.Cells[currentRow, 1].Style.Font.Size = 12;
                        worksheet.Cells[currentRow, 1].Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                        worksheet.Cells[currentRow, 1].Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.LightGray);
                        currentRow++;

                        // Заголовки колонок для категории
                        worksheet.Cells[currentRow, 1].Value = "Профиль";
                        worksheet.Cells[currentRow, 2].Value = "Количество в избранном";
                        worksheet.Cells[currentRow, 3].Value = "Процент в категории";
                        worksheet.Cells[currentRow, 1, currentRow, 3].Style.Font.Bold = true;
                        currentRow++;

                        // Получаем профили для текущей категории
                        var profiles = db.Favorite
                            .Include(f => f.Size)
                            .Include(f => f.Size.Product)
                            .Include(f => f.Size.Product.Category)
                            .Where(f => f.Size != null &&
                                        f.Size.Product != null &&
                                        f.Size.Product.Category != null &&
                                        f.Size.Product.Category.CategoryName == category.CategoryName)
                            .GroupBy(f => f.Size.SizeName)
                            .Select(g => new { ProfileName = g.Key, Count = g.Count() })
                            .OrderByDescending(p => p.Count)
                            .ToList();

                        int categoryTotal = profiles.Sum(p => p.Count);

                        // Данные профилей
                        foreach (var profile in profiles)
                        {
                            double percentage = categoryTotal > 0 ? (profile.Count * 100.0 / categoryTotal) : 0;
                            worksheet.Cells[currentRow, 1].Value = profile.ProfileName;
                            worksheet.Cells[currentRow, 2].Value = profile.Count;
                            worksheet.Cells[currentRow, 3].Value = $"{percentage:F1}%";
                            currentRow++;
                        }

                        // Итог по категории
                        worksheet.Cells[currentRow, 1].Value = "ИТОГО по категории:";
                        worksheet.Cells[currentRow, 2].Value = categoryTotal;
                        worksheet.Cells[currentRow, 2].Style.Font.Bold = true;
                        worksheet.Cells[currentRow, 3].Value = "100%";
                        worksheet.Cells[currentRow, 1, currentRow, 3].Style.Font.Bold = true;
                        currentRow += 2; // Пустая строка между категориями
                    }
                }

                worksheet.Cells.AutoFitColumns();

                var saveDialog = new Microsoft.Win32.SaveFileDialog
                {
                    Filter = "Excel файлы|*.xlsx",
                    FileName = $"Полная_статистика_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx"
                };

                if (saveDialog.ShowDialog() == true)
                {
                    System.IO.File.WriteAllBytes(saveDialog.FileName, package.GetAsByteArray());
                    MessageBox.Show("Экспорт выполнен успешно!", "Успех");
                }
            }
        }

