        private void LoadUserInfo()
        {
            using (var db = new DiplomMurEntities())
            {
                var user = db.User.FirstOrDefault(u => u.UserID == _currentUserId);
                if (user != null)
                {
                    UserFioTextBlock.Text = $"{user.UserLastName} {user.UserFirstName} {user.UserPatronymic}".Trim();
                }
                UserImage.Source = new System.Windows.Media.Imaging.BitmapImage(
                    new Uri("/Resources/UserAvatar.png", UriKind.Relative));
            }
        }

        private class CategoryStats
