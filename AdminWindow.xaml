using System;
using System.Collections.Generic;
using System.Linq;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Input;
using System.Windows.Media;

namespace IS_GTS.Windows
{
    public partial class AddUserWindow : Window
    {
        private ToolTip _emailToolTip;

        public AddUserWindow()
        {
            InitializeComponent();
        }

        private void AddUserButton_Click(object sender, RoutedEventArgs e)
        {
            List<string> errors = new List<string>();

            // Проверка обязательных полей
            if (string.IsNullOrWhiteSpace(LastNameTextBox.Text))
                errors.Add("• Фамилия");

            if (string.IsNullOrWhiteSpace(FirstNameTextBox.Text))
                errors.Add("• Имя");

            if (string.IsNullOrWhiteSpace(EmailTextBox.Text))
                errors.Add("• Email");

            if (string.IsNullOrWhiteSpace(LoginTextBox.Text))
                errors.Add("• Логин");

            string password = PasswordBox.Password;
            string confirmPassword = ConfirmPasswordBox.Password;

            if (string.IsNullOrWhiteSpace(password))
                errors.Add("• Пароль");

            // Если есть ошибки - показываем
            if (errors.Count > 0)
            {
                string errorMessage = "Заполните обязательные поля:\n\n" + string.Join("\n", errors);
                MessageBox.Show(errorMessage, "Ошибка", MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            // Проверка пароля
            if (password != confirmPassword)
            {
                MessageBox.Show("Пароль и подтверждение не совпадают!",
                    "Ошибка", MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            if (password.Length < 4)
            {
                MessageBox.Show("Пароль должен содержать минимум 4 символа!",
                    "Ошибка", MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            // Проверка формата email
            string email = EmailTextBox.Text.Trim();
            if (!email.EndsWith("@gts.ru"))
            {
                MessageBox.Show("Email должен быть в формате: имя@gts.ru",
                    "Ошибка", MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            // Определяем роль
            int roleId = 2; // Инженер по умолчанию
            if (MainEngineerRadioButton.IsChecked == true)
                roleId = 3;
            else if (AdminRadioButton.IsChecked == true)
                roleId = 1;

            using (var db = new Data.DiplomMurEntities())
            {
                // Проверка уникальности логина
                var existingUser = db.User.FirstOrDefault(u => u.UserLogin == LoginTextBox.Text);
                if (existingUser != null)
                {
                    MessageBox.Show("Пользователь с таким логином уже существует!",
                        "Ошибка", MessageBoxButton.OK, MessageBoxImage.Warning);
                    return;
                }

                // Создаем нового пользователя
                var newUser = new Data.User
                {
                    UserLastName = LastNameTextBox.Text.Trim(),
                    UserFirstName = FirstNameTextBox.Text.Trim(),
                    UserPatronymic = string.IsNullOrWhiteSpace(PatronymicTextBox.Text) ? null : PatronymicTextBox.Text.Trim(),
                    UserDateBirth = BirthDatePicker.SelectedDate,
                    UserEmail = email,
                    UserPhone = string.IsNullOrWhiteSpace(PhoneTextBox.Text) ? null : PhoneTextBox.Text.Trim(),
                    UserLogin = LoginTextBox.Text.Trim(),
                    UserPassword = password,
                    UserRoleID = roleId,
                    UserIsBlocked = false
                };

                db.User.Add(newUser);
                db.SaveChanges();

                MessageBox.Show($"Пользователь {LastNameTextBox.Text} {FirstNameTextBox.Text} успешно добавлен!",
                    "Успех", MessageBoxButton.OK, MessageBoxImage.Information);

                this.DialogResult = true;
                this.Close();
            }
        }

        private void EmailTextBox_TextChanged(object sender, TextChangedEventArgs e)
        {
            string text = EmailTextBox.Text;

            // Проверяем, есть ли @ и нет ли уже домена
            if (text.Contains("@") && !text.Contains("@gts.ru"))
            {
                int atIndex = text.IndexOf("@");
                string suggestion = text.Substring(0, atIndex + 1) + "gts.ru";

                // Создаем ToolTip если его нет
                if (_emailToolTip == null)
                {
                    _emailToolTip = new ToolTip();
                    _emailToolTip.Placement = System.Windows.Controls.Primitives.PlacementMode.Bottom;
                    _emailToolTip.PlacementTarget = EmailTextBox;
                    _emailToolTip.BorderBrush = new SolidColorBrush(Colors.Gray);
                    _emailToolTip.BorderThickness = new Thickness(1);
                    _emailToolTip.Background = new SolidColorBrush(Color.FromRgb(255, 255, 225));
                    _emailToolTip.Padding = new Thickness(8);
                }

                // Формируем подсказку
                _emailToolTip.Content = $"Нажмите Tab для автозаполнения: {suggestion}";
                _emailToolTip.IsOpen = true;

                // Сохраняем предложение в Tag для использования в PreviewKeyDown
                EmailTextBox.Tag = suggestion;
            }
            else
            {
                // Если уже есть домен или нет @, скрываем подсказку
                if (_emailToolTip != null)
                {
                    _emailToolTip.IsOpen = false;
                }
                EmailTextBox.Tag = null;
            }
        }

        private void EmailTextBox_PreviewKeyDown(object sender, KeyEventArgs e)
        {
            // При нажатии Tab и наличии предложения
            if (e.Key == Key.Tab && EmailTextBox.Tag != null)
            {
                string suggestion = EmailTextBox.Tag.ToString();
                EmailTextBox.Text = suggestion;
                EmailTextBox.CaretIndex = suggestion.Length;
                EmailTextBox.Tag = null;

                // Скрываем подсказку
                if (_emailToolTip != null)
                {
                    _emailToolTip.IsOpen = false;
                }

                e.Handled = true; // Предотвращаем стандартное поведение Tab
            }
        }

        private void BackButton_Click(object sender, RoutedEventArgs e)
        {
            this.Close();
        }

        private void CancelButton_Click(object sender, RoutedEventArgs e)
        {
            this.Close();
        }
    }
}