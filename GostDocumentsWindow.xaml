        private List<string> GetAllCharacteristics()
        {
            var sourceData = _originalData ?? _productsData;
            if (sourceData == null || !sourceData.Any())
                return new List<string>();

            var characteristics = new HashSet<string>();
            foreach (var product in sourceData)
            {
                foreach (var charName in product.Characteristics.Keys)
                    characteristics.Add(charName);
            }
            return characteristics.OrderBy(c => c).ToList();
        }

        private void SettingButton_Click(object sender, RoutedEventArgs e)
        {
            try
            {
                var allCharacteristics = GetAllCharacteristics();
                var currentColumnSettings = GetColumnSettings();

                var filtersWindow = new FiltersWindow
                {
                    Owner = this,
                    Title = $"Фильтры и настройки отображения - ГОСТ {_gostNumber}",
                    AvailableCharacteristics = allCharacteristics,
                    CurrentFilters = _currentFilters,
                    CurrentColumns = currentColumnSettings
                };

                if (filtersWindow.ShowDialog() == true)
                {
                    _currentFilters = filtersWindow.CurrentFilters ?? new List<FilterSetting>();
                    if (filtersWindow.CurrentColumns != null && filtersWindow.CurrentColumns.Any())
                        ApplyColumnSettings(filtersWindow.CurrentColumns);
                    ApplyFilters();
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Ошибка при открытии настроек: {ex.Message}", "Ошибка");
            }
        }

        private List<ColumnSetting> GetColumnSettings()
        {
            var columnSettings = new List<ColumnSetting>();
            columnSettings.Add(new ColumnSetting
            {
                FieldName = "ProductName",
                DisplayName = "Профиль",
                IsVisible = true,
                Width = 120
            });

            var allCharacteristics = GetAllCharacteristics();
            foreach (var charName in allCharacteristics)
            {
                DataGridColumn existingColumn = null;
                foreach (DataGridColumn col in GostDataGrid.Columns)
                {
                    if (col.Header?.ToString()?.Contains(charName) == true)
                    {
                        existingColumn = col;
                        break;
                    }
                }

                string displayName = GetColumnHeader(charName);
                bool isVisible = existingColumn == null || existingColumn.Visibility == Visibility.Visible;
                double width;
                if (existingColumn != null && existingColumn.Width.IsAbsolute)
                    width = existingColumn.Width.Value;
                else
                    width = CalculateAutoWidth(displayName);

                columnSettings.Add(new ColumnSetting
                {
                    FieldName = charName,
                    DisplayName = displayName,
                    IsVisible = isVisible,
                    Width = width
                });
            }
            return columnSettings;
        }

        private List<string> GetCurrentCharacteristics()
        {
            if (_productsData == null || !_productsData.Any())
                return new List<string>();

            var characteristics = new HashSet<string>();
            foreach (var product in _productsData)
            {
                foreach (var charName in product.Characteristics.Keys)
                    characteristics.Add(charName);
            }
            return characteristics.OrderBy(c => c).ToList();
        }

        private string GetColumnHeader(string charName)
        {
            var context = Data.DiplomMurEntities.GetContext();
            var characteristic = context.Characteristic.FirstOrDefault(c => c.CharactName == charName);
            if (characteristic != null && !string.IsNullOrEmpty(characteristic.CharactDefaultUnit))
                return $"{charName} ({characteristic.CharactDefaultUnit})";
            return charName;
        }

        private void ApplyColumnSettings(List<ColumnSetting> columnSettings)
        {
            if (columnSettings == null || GostDataGrid.Columns.Count <= 1) return;
            if (GostDataGrid.Columns.Count > 0)
            {
                var profileWidth = columnSettings.FirstOrDefault(c => c.FieldName == "ProductName")?.Width ?? 120;
                GostDataGrid.Columns[0].Width = new DataGridLength(profileWidth);
            }
            for (int i = 1; i < GostDataGrid.Columns.Count; i++)
            {
                var column = GostDataGrid.Columns[i];
                var columnHeader = column.Header?.ToString();
                if (columnHeader != null)
                {
                    foreach (var setting in columnSettings)
                    {
                        if (columnHeader.Contains(setting.FieldName) || setting.DisplayName.Contains(columnHeader))
                        {
                            column.Visibility = setting.IsVisible ? Visibility.Visible : Visibility.Collapsed;
                            column.Width = new DataGridLength(setting.Width);
                            break;
                        }
                    }
                }
            }
            UpdateCountInfo();
        }

        private void ApplyFilters()
        {
            try
            {
                List<ProductCharacteristic> sourceData;
                if (_originalData != null && _originalData.Any())
                    sourceData = _originalData;
                else if (_productsData != null && _productsData.Any())
                {
                    sourceData = _productsData;
                    if (_originalData == null)
                        _originalData = new List<ProductCharacteristic>(_productsData);
                }
                else
                {
                    MessageBox.Show("Нет данных для фильтрации", "Информация");
                    return;
                }

                var filteredData = sourceData.ToList();
                var searchText = SearchTextBox.Text.Trim();
                if (!string.IsNullOrEmpty(searchText))
                {
                    string searchLower = searchText.ToLower();
                    filteredData = filteredData.Where(p => p != null && p.ProductName != null && p.ProductName.ToLower().Contains(searchLower)).ToList();
                }

                if (_currentFilters != null && _currentFilters.Any())
                {
                    foreach (var filter in _currentFilters)
                    {
                        if (filter == null || string.IsNullOrEmpty(filter.ParameterName)) continue;
                        var newFilteredData = new List<ProductCharacteristic>();
                        foreach (var product in filteredData)
                        {
                            if (product == null || product.Characteristics == null) continue;
                            if (product.Characteristics.ContainsKey(filter.ParameterName))
                            {
                                var charDetail = product.Characteristics[filter.ParameterName];
                                if (charDetail == null) continue;
                                decimal value = charDetail.Value;
                                if (value >= (decimal)filter.MinValue && value <= (decimal)filter.MaxValue)
                                    newFilteredData.Add(product);
                            }
                            else
                            {
                                var matchingKey = product.Characteristics.Keys.FirstOrDefault(k => k.Contains(filter.ParameterName) || filter.ParameterName.Contains(k));
                                if (matchingKey != null)
                                {
                                    var charDetail = product.Characteristics[matchingKey];
                                    decimal value = charDetail.Value;
                                    if (value >= (decimal)filter.MinValue && value <= (decimal)filter.MaxValue)
                                        newFilteredData.Add(product);
                                }
                            }
                        }
                        filteredData = newFilteredData;
                    }
                }

                _productsData = filteredData.OrderBy(p => p.ProductID).ToList();
                GostDataGrid.ItemsSource = _productsData;
                UpdateCountInfo();

                if (!_productsData.Any() && (sourceData.Count > 0 || !string.IsNullOrEmpty(searchText) || (_currentFilters != null && _currentFilters.Any())))
                    MessageBox.Show("Нет данных, соответствующих заданным фильтрам", "Информация");
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Ошибка при применении фильтров: {ex.Message}", "Ошибка");
            }
        }

