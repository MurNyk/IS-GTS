        private void LoadFavoritesState()
        {
            if (_productsData == null || !_productsData.Any() || _currentUserId <= 0) return;

            try
            {
                using (var context = new Data.DiplomMurEntities())
                {
                    var sizeIds = _productsData.Select(p => p.SizeID).ToList();

                    var favorites = context.Favorite
                        .Where(f => f.FavoriteUserID == _currentUserId
                        && sizeIds.Contains(f.FavoriteProductSizeID))
                        .Select(f => new
                        {
                            f.FavoriteProductSizeID,
                            f.FavoriteFolderName
                        })
                        .ToList();

                    var favoritesDict = favorites
                        .ToDictionary(f => f.FavoriteProductSizeID, f => f.FavoriteFolderName);

                    foreach (var product in _productsData)
                    {
                        if (favoritesDict.ContainsKey(product.SizeID))
                        {
                            product.IsFavorite = true;
                            product.FolderName = favoritesDict[product.SizeID];
                        }
                        else
                        {
                            product.IsFavorite = false;
                            product.FolderName = null;
                        }

                        product.IsSelectedProfile = (_selectedSizeId.HasValue && product.SizeID == _selectedSizeId.Value);
                    }
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Ошибка загрузки избранного: {ex.Message}", "Ошибка", MessageBoxButton.OK, MessageBoxImage.Error);
            }
        }

        private bool AddToFavorite(int sizeId, string profileName)
        {
            if (_currentUserId <= 0)
            {
                MessageBox.Show("Войдите в систему для добавления в избранное", "Ошибка");
                return false;
            }
            try
            {
                using (var context = new Data.DiplomMurEntities())
                {
                    var existing = context.Favorite
                        .FirstOrDefault(f => f.FavoriteUserID == _currentUserId
                                          && f.FavoriteProductSizeID == sizeId);

                    if (existing != null) return false;

                    var favorite = new Data.Favorite
                    {
                        FavoriteUserID = _currentUserId,
                        FavoriteProductSizeID = sizeId,
                        FavoriteCreate = DateTime.Now,
                        FavoriteFolderName = null
                    };

                    context.Favorite.Add(favorite);
                    context.SaveChanges();
                    return true;
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Ошибка: {ex.Message}", "Ошибка");
                return false;
            }
        }

        private bool RemoveFromFavorite(int sizeId)
        {
            try
            {
                using (var context = new Data.DiplomMurEntities())
                {
                    var favorite = context.Favorite
                        .FirstOrDefault(f => f.FavoriteUserID == _currentUserId
                        && f.FavoriteProductSizeID == sizeId);
                    if (favorite == null) return false;

                    context.Favorite.Remove(favorite);
                    context.SaveChanges();
                    return true;
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Ошибка: {ex.Message}", "Ошибка");
                return false;
            }
        }

        private void GostDataGrid_MouseDoubleClick(object sender, MouseButtonEventArgs e)
        {
            var row = ItemsControl.ContainerFromElement(GostDataGrid,
                        e.OriginalSource as DependencyObject) as DataGridRow;
            if (row == null) return;
            if (e.OriginalSource is DataGridColumnHeader) return;
            var product = row.DataContext as ProductCharacteristic;
            if (product == null) return;
            HandleFavoriteAction(product);
            e.Handled = true;
        }

        private void HandleFavoriteAction(ProductCharacteristic product)
        {
            if (product.IsFavorite)
            {
                var result = MessageBox.Show($"Удалить '{product.ProductName}' из избранного?", "Удаление", MessageBoxButton.YesNo, MessageBoxImage.Question);
                if (result == MessageBoxResult.Yes)
                {
                    if (RemoveFromFavorite(product.SizeID))
                    {
                        product.IsFavorite = false;
                        GostDataGrid.Items.Refresh();
                    }
                }
            }
            else
            {
                var result = MessageBox.Show($"Добавить '{product.ProductName}' в избранное?", "Добавление", MessageBoxButton.YesNo, MessageBoxImage.Question);
                if (result == MessageBoxResult.Yes)
                {
                    if (AddToFavorite(product.SizeID, product.ProductName))
                    {
                        product.IsFavorite = true;
                        GostDataGrid.Items.Refresh();
                    }
                }
            }
        }

        private void LoadGostDrawing()
        {
            try
            {
                string projectPath = Directory.GetParent(AppDomain.CurrentDomain.BaseDirectory)?.Parent?.Parent?.FullName ?? AppDomain.CurrentDomain.BaseDirectory;
                string resourcesPath = System.IO.Path.Combine(projectPath, "Resources");
                if (!Directory.Exists(resourcesPath))
                {
                    Directory.CreateDirectory(resourcesPath);
                    return;
                }
                string fileName = _gostNumber.Replace("ГОСТ", "").Replace(" ", "").Trim();
                string filePath = System.IO.Path.Combine(resourcesPath, fileName + ".jpg");
                if (File.Exists(filePath))
                {
                    LoadImage(filePath);
                    return;
                }
                filePath = System.IO.Path.Combine(resourcesPath, fileName + ".png");
                if (File.Exists(filePath))
                {
                    LoadImage(filePath);
                    return;
                }
                string noPhotoPath = System.IO.Path.Combine(resourcesPath, "No_gost_photo.jpg");
                if (File.Exists(noPhotoPath))
                {
                    LoadImage(noPhotoPath);
                }
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"Ошибка: {ex.Message}");
            }
        }

        private void LoadImage(string path)
        {
            var bitmap = new BitmapImage(new Uri(path, UriKind.Absolute));
            GostDrawingImage.Source = bitmap;
        }

        private void LoadGostDetails()
        {
            try
            {
                LoadDataFromDatabase();

                if (_productsData == null || !_productsData.Any())
                {
                    MessageBox.Show("Для данного ГОСТа нет типоразмеров", "Информация", MessageBoxButton.OK, MessageBoxImage.Error);
                    this.Close();
                    return;
                }

                SetupDynamicColumns();
                LoadDataIntoTable();
                UpdateCountInfo();

                if (_selectedSizeId.HasValue)
                {
                    Dispatcher.BeginInvoke(new Action(() =>
                    {
                        var selectedItem = _productsData.FirstOrDefault(p => p.SizeID == _selectedSizeId.Value);
                        if (selectedItem != null)
                        {
                            GostDataGrid.SelectedItem = selectedItem;
                            GostDataGrid.ScrollIntoView(selectedItem);
                        }
                    }), System.Windows.Threading.DispatcherPriority.Loaded);
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Ошибка загрузки данных ГОСТа: {ex.Message}", "Ошибка", MessageBoxButton.OK, MessageBoxImage.Error);
                this.Close();
            }
        }

        private void SetupDynamicColumns()
        {
            GostDataGrid.Columns.Clear();

            if (_productsData == null || !_productsData.Any())
                return;

            _productsData = _productsData.OrderBy(p => p.ProductID).ToList();

            Style standardCellStyle = new Style(typeof(DataGridCell));
            standardCellStyle.Setters.Add(new Setter(TextBlock.TextWrappingProperty, TextWrapping.Wrap));
            standardCellStyle.Setters.Add(new Setter(Control.VerticalContentAlignmentProperty, VerticalAlignment.Center));
            standardCellStyle.Setters.Add(new Setter(Control.PaddingProperty, new Thickness(4)));
            standardCellStyle.Setters.Add(new Setter(TextBlock.TextAlignmentProperty, TextAlignment.Center));
            standardCellStyle.Setters.Add(new Setter(Control.BorderBrushProperty, Brushes.LightGray));
            standardCellStyle.Setters.Add(new Setter(Control.BorderThicknessProperty, new Thickness(0, 0, 1, 1)));

            Style profileCellStyle = new Style(typeof(DataGridCell));
            profileCellStyle.Setters.Add(new Setter(TextBlock.TextWrappingProperty, TextWrapping.Wrap));
            profileCellStyle.Setters.Add(new Setter(Control.VerticalContentAlignmentProperty, VerticalAlignment.Center));
            profileCellStyle.Setters.Add(new Setter(Control.PaddingProperty, new Thickness(4)));
            profileCellStyle.Setters.Add(new Setter(TextBlock.TextAlignmentProperty, TextAlignment.Left));
            profileCellStyle.Setters.Add(new Setter(Control.BorderBrushProperty, Brushes.LightGray));
            profileCellStyle.Setters.Add(new Setter(Control.BorderThicknessProperty, new Thickness(0, 0, 1, 1)));

            var favoriteColumn = new DataGridTemplateColumn
            {
                Header = "★",
                Width = 40,
                IsReadOnly = true,
                CanUserSort = true,
                CanUserResize = false
            };

            DataTemplate cellTemplate = new DataTemplate();
            FrameworkElementFactory borderFactory = new FrameworkElementFactory(typeof(Border));
            borderFactory.SetValue(Border.BackgroundProperty, Brushes.Transparent);
            borderFactory.SetValue(Border.PaddingProperty, new Thickness(8));

            FrameworkElementFactory imageFactory = new FrameworkElementFactory(typeof(Image));
            imageFactory.SetValue(Image.WidthProperty, 24.0);
            imageFactory.SetValue(Image.HeightProperty, 24.0);
            imageFactory.SetValue(Image.StretchProperty, Stretch.Uniform);

            Binding sourceBinding = new Binding("IsFavorite")
            {
                Converter = new FavoriteImageConverter()
            };
            imageFactory.SetBinding(Image.SourceProperty, sourceBinding);

            borderFactory.AppendChild(imageFactory);
            cellTemplate.VisualTree = borderFactory;
            favoriteColumn.CellTemplate = cellTemplate;
            favoriteColumn.CellStyle = standardCellStyle;
            GostDataGrid.Columns.Add(favoriteColumn);

            var profileColumn = new DataGridTextColumn
            {
                Header = "Профиль",
                Binding = new Binding("ProductName"),
                Width = 120,
                IsReadOnly = true,
                CanUserSort = true
            };
            profileColumn.CellStyle = profileCellStyle;
            GostDataGrid.Columns.Add(profileColumn);

            var uniqueCharacteristics = new HashSet<string>();
            foreach (var product in _productsData)
            {
                foreach (var charName in product.Characteristics.Keys)
                {
                    uniqueCharacteristics.Add(charName);
                }
            }

            var context = Data.DiplomMurEntities.GetContext();
            var charInfoFromDb = context.Characteristic
                .Where(c => uniqueCharacteristics.Contains(c.CharactName))
                .ToDictionary(c => c.CharactName, c => c.CharactDefaultUnit ?? "");

            foreach (var charName in uniqueCharacteristics.OrderBy(c => c))
            {
                string unit = charInfoFromDb.ContainsKey(charName) ? charInfoFromDb[charName] : "";
                string header = string.IsNullOrEmpty(unit) ? charName : $"{charName} ({unit})";

                var charColumn = new DataGridTextColumn
                {
                    Header = header,
                    Binding = new Binding($"Characteristics[{charName}].DisplayValue"),
                    Width = CalculateAutoWidth(header),
                    IsReadOnly = true,
                    CanUserSort = true
                };
                charColumn.CellStyle = standardCellStyle;
                GostDataGrid.Columns.Add(charColumn);
            }
        }

        private double CalculateAutoWidth(string headerText)
        {
            int textLength = headerText.Length;
            if (textLength < 6) return 80;
            if (textLength < 10) return 90;
            if (textLength < 14) return 110;
            if (textLength < 18) return 130;
            if (textLength < 22) return 150;
            return 170;
        }

