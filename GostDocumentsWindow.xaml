        private double _currentScale = 1.0;
        private const double ZOOM_STEP = 0.2;
        private const double MIN_SCALE = 0.1;
        private const double MAX_SCALE = 5.0;

        private double _profileZoom = 1.0;

        private void ZoomIn_Click(object sender, RoutedEventArgs e)
        {
            _profileZoom += 0.1;
            if (_profileZoom > 2.0) _profileZoom = 2.0;
            ApplyProfileZoom();
        }

        private void ZoomOut_Click(object sender, RoutedEventArgs e)
        {
            _profileZoom -= 0.1;
            if (_profileZoom < 0.5) _profileZoom = 0.5;
            ApplyProfileZoom();
        }

        private void ZoomReset_Click(object sender, RoutedEventArgs e)
        {
            _profileZoom = 1.0;
            ApplyProfileZoom();
        }

        private void ApplyProfileZoom()
        {
            var scaleTransform = new ScaleTransform(_profileZoom, _profileZoom);
            _profileCanvas.LayoutTransform = scaleTransform;
        }
        private void ZoomIn()
        {
            if (_currentScale >= MAX_SCALE) return;
            _currentScale += ZOOM_STEP;
            ApplyZoom();
        }

        private void ZoomOut()
        {
            if (_currentScale <= MIN_SCALE) return;
            _currentScale -= ZOOM_STEP;
            ApplyZoom();
        }

        private void ZoomReset()
        {
            _currentScale = 1.0;
            ApplyZoom();
        }

        private void ApplyZoom()
        {
            if (GostDrawingImage == null) return;
            var scaleTransform = new ScaleTransform(_currentScale, _currentScale);
            GostDrawingImage.LayoutTransform = scaleTransform;
        }

