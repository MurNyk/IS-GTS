        private void DrawCircle()
        {
            double canvasW = _profileCanvas.Width;
            double canvasH = _profileCanvas.Height;

            // Радиус = диаметр / 2, масштабируем под Canvas
            double diameter = _profileHeight; // это и есть диаметр
            double size = Math.Min(canvasW - 40, diameter);
            if (size <= 0) size = 60;

            var circle = new Ellipse
            {
                Width = size,
                Height = size,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 2
            };

            Canvas.SetLeft(circle, (canvasW - size) / 2);
            Canvas.SetTop(circle, (canvasH - size) / 2);
            _profileCanvas.Children.Add(circle);
        }

        private void DrawAngle()
        {
            double canvasW = _profileCanvas.Width;
            double canvasH = _profileCanvas.Height;

            double width = Math.Min(canvasW - 60, _profileWidth);
            double height = Math.Min(canvasH - 60, _profileHeight);
            if (width <= 0) width = 60;
            if (height <= 0) height = 60;

            double thickness = Math.Min(width / 5, height / 5);

            var geometry = new StreamGeometry();
            using (var ctx = geometry.Open())
            {
                ctx.BeginFigure(new Point(canvasW / 2 - width / 2, canvasH / 2 - height / 2), true, true);
                ctx.LineTo(new Point(canvasW / 2 + width / 2, canvasH / 2 - height / 2), true, false);
                ctx.LineTo(new Point(canvasW / 2 + width / 2, canvasH / 2 + height / 2), true, false);
                ctx.LineTo(new Point(canvasW / 2 + width / 2 - thickness, canvasH / 2 + height / 2), true, false);
                ctx.LineTo(new Point(canvasW / 2 + width / 2 - thickness, canvasH / 2 - height / 2 + thickness), true, false);
                ctx.LineTo(new Point(canvasW / 2 - width / 2, canvasH / 2 - height / 2 + thickness), true, false);
            }

            var angle = new System.Windows.Shapes.Path
            {
                Data = geometry,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 1
            };
            _profileCanvas.Children.Add(angle);
        }

