        private void UpdateCountInfo()
        {
            if (_productsData != null)
            {
                ColumnsCountText.Text = (GostDataGrid.Columns.Count - 1).ToString();
                int filteredRows = _productsData.Count;
                int totalRows = _originalData?.Count ?? filteredRows;

                if (filteredRows == totalRows)
                    RowsCountText.Text = $"{totalRows}";
                else
                    RowsCountText.Text = $"{filteredRows} из {totalRows}";
            }
        }

        private void LoadDataFromDatabase()
        {
            var context = Data.DiplomMurEntities.GetContext();

            var product = context.Product
                .Include(p => p.Category)
                .Include(p => p.Category.Material)
                .OrderBy(p => p.ProductID)
                .FirstOrDefault(p => p.ProductStandartNumber == _gostNumber);

            if (product != null)
            {
                Title = $"ГОСТ {_gostNumber} - {product.Category?.CategoryName}";
                GostNumber.Text = $"ГОСТ: {_gostNumber}";
                GostTitleText.Text = $"{product.Category?.CategoryName} ({product.Category?.Material?.MaterialName})";
                ProductsCountText.Text = $"Стандарт: {product.ProductStandartName}";
            }

            var sizes = context.Size
                .Include(s => s.Product)
                .Where(s => s.Product.ProductStandartNumber == _gostNumber)
                .ToList();

            if (!sizes.Any())
            {
                _productsData = new List<ProductCharacteristic>();
                return;
            }

            var sizeIds = sizes.Select(s => s.SizeID).ToList();
            var allCharacteristics = context.CharacteristicValue
                .Include(cv => cv.Characteristic)
                .Where(cv => sizeIds.Contains(cv.ValueSizeID))
                .ToList();

            var characteristicsBySize = allCharacteristics
                .GroupBy(cv => cv.ValueSizeID)
                .ToDictionary(g => g.Key, g => g.ToList());

            _productsData = new List<ProductCharacteristic>();

            foreach (var size in sizes)
            {
                var productChar = new ProductCharacteristic
                {
                    ProductID = size.Product?.ProductID ?? 0,
                    SizeID = size.SizeID,
                    ProductName = size.SizeName,
                    NominalValue = size.SizeNominalValue,
                    IsFavorite = false
                };

                if (characteristicsBySize.ContainsKey(size.SizeID))
                {
                    var groupedByCharName = characteristicsBySize[size.SizeID]
                        .Where(cv => cv.Characteristic != null)
                        .GroupBy(cv => cv.Characteristic.CharactName)
                        .ToDictionary(g => g.Key, g => g.ToList());

                    foreach (var group in groupedByCharName)
                    {
                        string charName = group.Key;
                        var values = group.Value;

                        if (productChar.Characteristics.ContainsKey(charName))
                            continue;

                        if (values.Count > 1)
                        {
                            if (charName.Equals("масса", StringComparison.OrdinalIgnoreCase) ||
                                charName.Equals("вес", StringComparison.OrdinalIgnoreCase) ||
                                charName.Equals("масса 1м", StringComparison.OrdinalIgnoreCase))
                            {
                                var massValue = values.FirstOrDefault(v => v.ValueNumeric.HasValue) ?? values.First();
                                string unit = massValue.ValueUnit ?? massValue.Characteristic?.CharactDefaultUnit ?? "";
                                string displayValue = FormatCharacteristicValue(massValue, unit);

                                if (!string.IsNullOrEmpty(displayValue))
                                {
                                    decimal valueToStore = massValue.ValueNumeric.HasValue
                                        ? massValue.ValueNumeric.Value
                                        : (massValue.ValueTolerance.HasValue ? massValue.ValueTolerance.Value : 0);

                                    productChar.Characteristics[charName] = new CharacteristicDetail
                                    {
                                        Value = valueToStore,
                                        Unit = unit,
                                        DisplayValue = displayValue
                                    };
                                }
                                continue;
                            }

                            var sortedValues = values.OrderBy(v => v.ValueToleranceDirection).ToList();
                            string combinedDisplayValue = string.Join(Environment.NewLine, sortedValues
                                .Select(cv =>
                                {
                                    string unit = cv.ValueUnit ?? cv.Characteristic?.CharactDefaultUnit ?? "";
                                    return FormatCharacteristicValue(cv, unit);
                                })
                                .Where(v => !string.IsNullOrEmpty(v)));

                            if (!string.IsNullOrEmpty(combinedDisplayValue))
                            {
                                string unit = values.First().ValueUnit ?? values.First().Characteristic?.CharactDefaultUnit ?? "";
                                var mainValue = values.FirstOrDefault(v => v.ValueTolerance == null && v.ValueNumeric.HasValue)
                                    ?? values.FirstOrDefault(v => v.ValueNumeric.HasValue);
                                decimal valueToStore = mainValue != null && mainValue.ValueNumeric.HasValue
                                    ? mainValue.ValueNumeric.Value : 0;

                                productChar.Characteristics[charName] = new CharacteristicDetail
                                {
                                    Value = valueToStore,
                                    Unit = unit,
                                    DisplayValue = combinedDisplayValue
                                };
                            }
                        }
                        else
                        {
                            var cv = values.First();
                            if (cv.Characteristic != null)
                            {
                                string unit = cv.ValueUnit ?? cv.Characteristic.CharactDefaultUnit ?? "";
                                string displayValue = FormatCharacteristicValue(cv, unit);

                                if (!string.IsNullOrEmpty(displayValue))
                                {
                                    decimal valueToStore = cv.ValueNumeric.HasValue
                                        ? cv.ValueNumeric.Value
                                        : (cv.ValueTolerance.HasValue ? cv.ValueTolerance.Value : 0);

                                    productChar.Characteristics[charName] = new CharacteristicDetail
                                    {
                                        Value = valueToStore,
                                        Unit = unit,
                                        DisplayValue = displayValue
                                    };
                                }
                            }
                        }
                    }
                }
                _productsData.Add(productChar);
            }
            LoadFavoritesState();
        }

        private string FormatCharacteristicValue(Data.CharacteristicValue cv, string unit)
        {
            if (cv.ValueTolerance.HasValue && !string.IsNullOrEmpty(cv.ValueToleranceDirection))
            {
                string toleranceSign = cv.ValueToleranceDirection;
                string formattedValue;
                if (cv.ValueNumeric.HasValue)
                    formattedValue = $"{toleranceSign}{cv.ValueTolerance.Value:F2}";
                else
                    formattedValue = $"{toleranceSign}{cv.ValueTolerance.Value:F2}";

                return string.IsNullOrEmpty(unit) ? formattedValue : $"{formattedValue} {unit}";
            }
            if (cv.ValueNumeric.HasValue)
            {
                return string.IsNullOrEmpty(unit) ? $"{cv.ValueNumeric.Value:F2}" : $"{cv.ValueNumeric.Value:F2} {unit}";
            }
            if (!string.IsNullOrEmpty(cv.ValueString))
            {
                return string.IsNullOrEmpty(unit) ? cv.ValueString : $"{cv.ValueString} {unit}";
            }
            return string.Empty;
        }

        private static T FindVisualChild<T>(DependencyObject obj) where T : DependencyObject
        {
            for (int i = 0; i < VisualTreeHelper.GetChildrenCount(obj); i++)
            {
                DependencyObject child = VisualTreeHelper.GetChild(obj, i);
                if (child != null)
                {
                    if (child is T)
                        return (T)child;
                    T childOfChild = FindVisualChild<T>(child);
                    if (childOfChild != null)
                        return childOfChild;
                }
            }
            return null;
        }

