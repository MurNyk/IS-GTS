        private void LoadProfileParameters(int sizeId)
        {
            using (var db = new Data.DiplomMurEntities())
            {
                var values = db.CharacteristicValue
                    .Include(cv => cv.Characteristic)
                    .Where(cv => cv.ValueSizeID == sizeId)
                    .ToList();

                var size = db.Size
                    .Include(s => s.Product)
                    .Include(s => s.Product.Category)
                    .FirstOrDefault(s => s.SizeID == sizeId);

                if (size?.Product?.Category != null)
                {
                    string categoryName = size.Product.Category.CategoryName;

                    if (categoryName.Contains("Круглый"))
                        _profileType = "Круглый";
                    else if (categoryName.Contains("Квадратный"))
                        _profileType = "Квадратный";
                    else if (categoryName.Contains("Полосовой"))
                        _profileType = "Полосовой";
                    else if (categoryName.Contains("Двутавр"))
                        _profileType = "Двутавр";
                    else if (categoryName.Contains("Швеллер"))
                        _profileType = "Швеллер";
                    else if (categoryName.Contains("Уголок"))
                        _profileType = "Уголок";
                    else
                        _profileType = categoryName;
                }

                // Сбрасываем значения
                _profileHeight = 0;
                _profileWidth = 0;
                _webThickness = 0;
                _flangeThickness = 0;

                // 🟢 КРУГЛЫЙ ПРОКАТ
                if (_profileType == "Круглый")
                {
                    var diameter = values.FirstOrDefault(v => v.ValueCharactID == 10);
                    if (diameter != null)
                        _profileHeight = _profileWidth = (double)diameter.ValueNumeric;
                }
                // 🟢 КВАДРАТНЫЙ ПРОКАТ
                else if (_profileType == "Квадратный")
                {
                    var side = values.FirstOrDefault(v => v.ValueCharactID == 15);
                    if (side != null)
                        _profileHeight = _profileWidth = (double)side.ValueNumeric;
                }
                // 🟢 ПОЛОСОВОЙ ПРОКАТ
                else if (_profileType == "Полосовой")
                {
                    var width = values.FirstOrDefault(v => v.ValueCharactID == 1);
                    var thickness = values.FirstOrDefault(v => v.ValueCharactID == 2);
                    if (width != null) _profileWidth = (double)width.ValueNumeric;
                    if (thickness != null) _profileHeight = (double)thickness.ValueNumeric;
                }
                // 🟢 ДВУТАВР
                else if (_profileType == "Двутавр")
                {
                    var height = values.FirstOrDefault(v => v.ValueCharactID == 16);
                    var flangeWidth = values.FirstOrDefault(v => v.ValueCharactID == 1);
                    var webThick = values.FirstOrDefault(v => v.ValueCharactID == 17);
                    var flangeThick = values.FirstOrDefault(v => v.ValueCharactID == 18);
                    if (height != null) _profileHeight = (double)height.ValueNumeric;
                    if (flangeWidth != null) _profileWidth = (double)flangeWidth.ValueNumeric;
                    if (webThick != null) _webThickness = (double)webThick.ValueNumeric;
                    if (flangeThick != null) _flangeThickness = (double)flangeThick.ValueNumeric;
                }

                // Если значения не найдены, устанавливаем значения по умолчанию
                if (_profileHeight <= 0) _profileHeight = 60;
                if (_profileWidth <= 0) _profileWidth = 60;
                if (_webThickness <= 0) _webThickness = 5;
                if (_flangeThickness <= 0) _flangeThickness = 5;
            }
        }
        private void DrawIBeamWithMainDimension()
        {
            double canvasW = _profileCanvas.Width;
            double canvasH = _profileCanvas.Height;
            double scale = Math.Min(canvasW / (_profileWidth + 30), canvasH / (_profileHeight + 30));
            if (scale <= 0) scale = 1;

            double centerX = canvasW / 2;
            double centerY = canvasH / 2;

            double h = _profileHeight * scale;
            double b = _profileWidth * scale;
            double s = _webThickness * scale;
            double t = _flangeThickness * scale;
            if (s < 2) s = 4;
            if (t < 2) t = 4;

            // Стенка
            var web = new Rectangle
            {
                Width = s,
                Height = h - 2 * t,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 1
            };
            Canvas.SetLeft(web, centerX - s / 2);
            Canvas.SetTop(web, centerY - h / 2 + t);
            _profileCanvas.Children.Add(web);

            // Верхняя полка
            var topFlange = new Rectangle
            {
                Width = b,
                Height = t,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 1
            };
            Canvas.SetLeft(topFlange, centerX - b / 2);
            Canvas.SetTop(topFlange, centerY - h / 2);
            _profileCanvas.Children.Add(topFlange);

            // Нижняя полка
            var bottomFlange = new Rectangle
            {
                Width = b,
                Height = t,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 1
            };
            Canvas.SetLeft(bottomFlange, centerX - b / 2);
            Canvas.SetTop(bottomFlange, centerY + h / 2 - t);
            _profileCanvas.Children.Add(bottomFlange);

            // Одна выносная линия для высоты h
            AddSingleDimensionLine(centerX, centerY - h / 2, centerX, centerY + h / 2, "h", _profileHeight);
        }

        private void DrawCurrentProfile()
        {
            if (_profileCanvas == null) return;
            _profileCanvas.Children.Clear();
            _dimensionLines.Clear();

            if (_profileType == "Круглый")
                DrawCircleWithMainDimension();
            else if (_profileType == "Двутавр")
                DrawIBeamWithMainDimension();
            else if (_profileType == "Швеллер")
                DrawChannelWithMainDimension();
            else if (_profileType == "Уголок")
                DrawAngleWithMainDimension();
            else if (_profileType == "Полосовой")
                DrawStripWithMainDimension();
            else if (_profileType == "Квадратный")
                DrawSquareWithMainDimension();
            else
                DrawRectangle();

            AddDimensions(); // дополнительная таблица внизу (опционально)
        }
        private void DrawSquareWithMainDimension()
        {
            double canvasW = _profileCanvas.Width;
            double canvasH = _profileCanvas.Height;

            double side = _profileHeight;
            double size = Math.Min(canvasW - 40, side);
            if (size <= 0) size = 60;

            double left = (canvasW - size) / 2;
            double top = (canvasH - size) / 2;

            var rect = new Rectangle
            {
                Width = size,
                Height = size,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 2
            };
            Canvas.SetLeft(rect, left);
            Canvas.SetTop(rect, top);
            _profileCanvas.Children.Add(rect);

            // Одна выносная линия для стороны a
            AddSingleDimensionLine(left - 15, top + size / 2, left + size + 15, top + size / 2, "a", _profileHeight);
        }

        private void DrawAngleWithMainDimension()
        {
            double canvasW = _profileCanvas.Width;
            double canvasH = _profileCanvas.Height;

            double width = Math.Min(canvasW - 60, _profileWidth);
            double height = Math.Min(canvasH - 60, _profileHeight);
            if (width <= 0) width = 60;
            if (height <= 0) height = 60;

            double thickness = Math.Min(width / 5, height / 5);

            var geometry = new StreamGeometry();
            using (var ctx = geometry.Open())
            {
                ctx.BeginFigure(new Point(canvasW / 2 - width / 2, canvasH / 2 - height / 2), true, true);
                ctx.LineTo(new Point(canvasW / 2 + width / 2, canvasH / 2 - height / 2), true, false);
                ctx.LineTo(new Point(canvasW / 2 + width / 2, canvasH / 2 + height / 2), true, false);
                ctx.LineTo(new Point(canvasW / 2 + width / 2 - thickness, canvasH / 2 + height / 2), true, false);
                ctx.LineTo(new Point(canvasW / 2 + width / 2 - thickness, canvasH / 2 - height / 2 + thickness), true, false);
                ctx.LineTo(new Point(canvasW / 2 - width / 2, canvasH / 2 - height / 2 + thickness), true, false);
            }

            var angle = new System.Windows.Shapes.Path
            {
                Data = geometry,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 1
            };
            _profileCanvas.Children.Add(angle);

            // Одна выносная линия для ширины полки b
            AddSingleDimensionLine(canvasW / 2 - width / 2 - 15, canvasH / 2, canvasW / 2 + width / 2 + 15, canvasH / 2, "b", _profileWidth);
        }

        private void AddSingleDimensionLine(double x1, double y1, double x2, double y2, string paramName, double value)
        {
            // Рисуем линию
            var line = new Line
            {
                X1 = x1,
                Y1 = y1,
                X2 = x2,
                Y2 = y2,
                Stroke = Brushes.Blue,
                StrokeThickness = 1.2,
                StrokeDashArray = new DoubleCollection { 4, 2 }
            };
            _profileCanvas.Children.Add(line);
            _dimensionLines.Add(line);

            // Добавляем стрелки на концах
            AddArrow(x1, y1, x2, y2);
            AddArrow(x2, y2, x1, y1);

            string text = $"{paramName} = {value:F1} мм";

            // Позиция подписи (посередине линии)
            double midX = (x1 + x2) / 2;
            double midY = (y1 + y2) / 2;

            var textBlock = new TextBlock
            {
                Text = text,
                FontSize = 11,
                FontWeight = FontWeights.SemiBold,
                Background = new SolidColorBrush(Color.FromArgb(230, 255, 255, 255)),
                Padding = new Thickness(4, 2, 4, 2),
                Foreground = Brushes.DarkBlue,
                Cursor = Cursors.Hand
            };

            Canvas.SetLeft(textBlock, midX - 35);
            Canvas.SetTop(textBlock, midY - 12);
            _profileCanvas.Children.Add(textBlock);

            // Подсветка линии при наведении на текст
            textBlock.MouseEnter += (s, e) => HighlightLine(line, true);
            textBlock.MouseLeave += (s, e) => HighlightLine(line, false);
            textBlock.ToolTip = $"{paramName} = {value:F1} мм";
        }
        private void DrawSquare()
        {
            double canvasW = _profileCanvas.Width;
            double canvasH = _profileCanvas.Height;

            // Сторона квадрата (a)
            double side = _profileHeight;
            double size = Math.Min(canvasW - 40, side);
            if (size <= 0) size = 60;

            var rect = new Rectangle
            {
                Width = size,
                Height = size,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 2
            };

            Canvas.SetLeft(rect, (canvasW - size) / 2);
            Canvas.SetTop(rect, (canvasH - size) / 2);
            _profileCanvas.Children.Add(rect);
        }

        private void DrawStrip()
        {
            double canvasW = _profileCanvas.Width;
            double canvasH = _profileCanvas.Height;

            // Ширина полосы (b) — большая сторона, Толщина (a) — малая сторона
            double width = Math.Min(canvasW - 60, _profileWidth * 2);   // ширина полосы (b)
            double height = Math.Min(canvasH - 60, _profileHeight * 5); // толщина (a)

            if (width <= 0) width = 120;
            if (height <= 0) height = 20;

            // Убеждаемся, что полоса выглядит как полоса (ширина > высоты)
            if (width < height)
            {
                // Меняем местами, если перепутано
                double temp = width;
                width = height;
                height = temp;
            }

            var rect = new Rectangle
            {
                Width = width,
                Height = height,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 2
            };

            Canvas.SetLeft(rect, (canvasW - width) / 2);
            Canvas.SetTop(rect, (canvasH - height) / 2);
            _profileCanvas.Children.Add(rect);
        }
        private void HighlightLine(Line line, bool highlight)
        {
            if (highlight)
            {
                line.Stroke = Brushes.Red;
                line.StrokeThickness = 2;
            }
            else
            {
                line.Stroke = Brushes.Blue;
                line.StrokeThickness = 1.2;
            }
        }
        private void DrawIBeam()
        {
            double canvasW = _profileCanvas.Width;
            double canvasH = _profileCanvas.Height;
            double scale = Math.Min(canvasW / (_profileWidth + 30), canvasH / (_profileHeight + 30));
            if (scale <= 0) scale = 1;

            double centerX = canvasW / 2;
            double centerY = canvasH / 2;

            double h = _profileHeight * scale;
            double b = _profileWidth * scale;
            double s = _webThickness * scale;
            double t = _flangeThickness * scale;
            if (s < 2) s = 4;
            if (t < 2) t = 4;

            // Создаём элементы для подсветки
            var topFlange = new Rectangle
            {
                Width = b,
                Height = t,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 1,
                Tag = "flange"
            };
            Canvas.SetLeft(topFlange, centerX - b / 2);
            Canvas.SetTop(topFlange, centerY - h / 2);
            _profileCanvas.Children.Add(topFlange);

            var bottomFlange = new Rectangle
            {
                Width = b,
                Height = t,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 1,
                Tag = "flange"
            };
            Canvas.SetLeft(bottomFlange, centerX - b / 2);
            Canvas.SetTop(bottomFlange, centerY + h / 2 - t);
            _profileCanvas.Children.Add(bottomFlange);

            var web = new Rectangle
            {
                Width = s,
                Height = h - 2 * t,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 1,
                Tag = "web"
            };
            Canvas.SetLeft(web, centerX - s / 2);
            Canvas.SetTop(web, centerY - h / 2 + t);
            _profileCanvas.Children.Add(web);

            // Добавляем выносные линии и подписи
            AddDimensionLine(centerX - b / 2 - 30, centerY - h / 2, centerX + b / 2 + 30, centerY - h / 2, "b", _profileWidth);
            AddDimensionLine(centerX - b / 2 - 30, centerY + h / 2, centerX + b / 2 + 30, centerY + h / 2, "b", _profileWidth);
            AddDimensionLine(centerX, centerY - h / 2, centerX, centerY + h / 2, "h", _profileHeight);
            AddDimensionLine(centerX - s / 2 - 20, centerY - h / 2 + t, centerX - s / 2 - 20, centerY + h / 2 - t, "s", _webThickness);
            AddDimensionLine(centerX + s / 2 + 20, centerY - h / 2 + t, centerX + s / 2 + 20, centerY + h / 2 - t, "s", _webThickness);
        }

        private void AddDimensionLine(double x1, double y1, double x2, double y2, string paramName, double value, double offset = 0)
        {
            // Если линия слишком короткая, рисуем подпись сбоку
            double lineLength = Math.Sqrt(Math.Pow(x2 - x1, 2) + Math.Pow(y2 - y1, 2));

            // Минимальная длина для размещения подписи внутри
            double minLengthForInside = 50;

            string text = $"{paramName} = {value:F1} мм";
            double textWidth = text.Length * 5; // примерная ширина текста

            // Рисуем линию
            var line = new Line
            {
                X1 = x1,
                Y1 = y1,
                X2 = x2,
                Y2 = y2,
                Stroke = Brushes.Blue,
                StrokeThickness = 0.8,
                StrokeDashArray = new DoubleCollection { 4, 2 }
            };
            _profileCanvas.Children.Add(line);

            // Стрелки
            AddArrow(x1, y1, x2, y2);
            AddArrow(x2, y2, x1, y1);

            // Позиция подписи
            double midX = (x1 + x2) / 2;
            double midY = (y1 + y2) / 2;
            double textX = midX - textWidth / 2;
            double textY = midY - 10;

            // Если линия слишком короткая, выносим подпись наружу
            if (lineLength < minLengthForInside)
            {
                double angle = Math.Atan2(y2 - y1, x2 - x1);
                textX = midX + Math.Cos(angle) * 30;
                textY = midY + Math.Sin(angle) * 30;
            }

            var textBlock = new TextBlock
            {
                Text = text,
                FontSize = 9,
                Background = Brushes.White,
                Padding = new Thickness(2),
                Foreground = Brushes.Black,
                Tag = paramName
            };

            Canvas.SetLeft(textBlock, textX);
            Canvas.SetTop(textBlock, textY);
            _profileCanvas.Children.Add(textBlock);

            // Подсветка
            textBlock.MouseEnter += (s, e) => HighlightParameter(paramName);
            textBlock.MouseLeave += (s, e) => UnhighlightParameter(paramName);
            textBlock.Cursor = Cursors.Hand;
            textBlock.ToolTip = $"Параметр: {paramName}\nЗначение: {value:F1} мм";
        }

        private void AddArrow(double x1, double y1, double x2, double y2)
        {
            double angle = Math.Atan2(y2 - y1, x2 - x1);
            double arrowSize = 5;

            // Проверяем, чтобы стрелка не выходила за пределы Canvas
            double xTip = Math.Max(5, Math.Min(_profileCanvas.Width - 5, x2));
            double yTip = Math.Max(5, Math.Min(_profileCanvas.Height - 5, y2));

            double xLeft = xTip - arrowSize * Math.Cos(angle - Math.PI / 6);
            double yLeft = yTip - arrowSize * Math.Sin(angle - Math.PI / 6);
            double xRight = xTip - arrowSize * Math.Cos(angle + Math.PI / 6);
            double yRight = yTip - arrowSize * Math.Sin(angle + Math.PI / 6);

            var arrow = new Polygon
            {
                Points = new PointCollection { new Point(xTip, yTip), new Point(xLeft, yLeft), new Point(xRight, yRight) },
                Fill = Brushes.Blue
            };
            _profileCanvas.Children.Add(arrow);
        }

        private void HighlightParameter(string paramName)
        {
            foreach (UIElement element in _profileCanvas.Children)
            {
                if (element is Rectangle rect)
                {
                    string tag = rect.Tag?.ToString();
                    if ((paramName == "b" && tag == "flange") ||
                        (paramName == "h" && tag == "web") ||
                        (paramName == "s" && tag == "web") ||
                        (paramName == "t" && tag == "flange"))
                    {
                        rect.Stroke = Brushes.Red;
                        rect.StrokeThickness = 3;
                        rect.Opacity = 0.8;
                    }
                }
            }
        }

        private void UnhighlightParameter(string paramName)
        {
            foreach (UIElement element in _profileCanvas.Children)
            {
                if (element is Rectangle rect)
                {
                    rect.Stroke = Brushes.Black;
                    rect.StrokeThickness = 1;
                    rect.Opacity = 1;
                }
            }
        }

        private void DrawCircleWithMainDimension()
        {
            double canvasW = _profileCanvas.Width;
            double canvasH = _profileCanvas.Height;
            double diameter = _profileHeight;
            double size = Math.Min(canvasW - 60, diameter);
            if (size <= 0) size = 60;

            var circle = new Ellipse
            {
                Width = size,
                Height = size,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 2
            };

            double left = (canvasW - size) / 2;
            double top = (canvasH - size) / 2;
            Canvas.SetLeft(circle, left);
            Canvas.SetTop(circle, top);
            _profileCanvas.Children.Add(circle);

            // Одна выносная линия для диаметра
            double centerX = canvasW / 2;
            double centerY = canvasH / 2;
            double rightX = left + size;

            AddSingleDimensionLine(centerX, centerY, rightX, centerY, "⌀", _profileHeight);
        }

        private void DrawStripWithMainDimension()
        {
            double canvasW = _profileCanvas.Width;
            double canvasH = _profileCanvas.Height;

            double width = Math.Min(canvasW - 60, _profileWidth * 2);
            double height = Math.Min(canvasH - 60, _profileHeight * 5);

            if (width <= 0) width = 120;
            if (height <= 0) height = 20;

            if (width < height)
            {
                double temp = width;
                width = height;
                height = temp;
            }

            double left = (canvasW - width) / 2;
            double top = (canvasH - height) / 2;

            var rect = new Rectangle
            {
                Width = width,
                Height = height,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 2
            };
            Canvas.SetLeft(rect, left);
            Canvas.SetTop(rect, top);
            _profileCanvas.Children.Add(rect);

            // Одна выносная линия для ширины b
            AddSingleDimensionLine(left - 15, top + height / 2, left + width + 15, top + height / 2, "b", _profileWidth);
        }
        private void DrawChannelWithMainDimension()
        {
            double canvasW = _profileCanvas.Width;
            double canvasH = _profileCanvas.Height;
            double scale = Math.Min(canvasW / (_profileWidth + 30), canvasH / (_profileHeight + 30));
            if (scale <= 0) scale = 1;

            double centerX = canvasW / 2;
            double centerY = canvasH / 2;

            double h = _profileHeight * scale;
            double b = _profileWidth * scale;
            double s = _webThickness * scale;
            if (s < 2) s = 4;

            var web = new Rectangle
            {
                Width = s,
                Height = h,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 1
            };
            Canvas.SetLeft(web, centerX - s / 2);
            Canvas.SetTop(web, centerY - h / 2);
            _profileCanvas.Children.Add(web);

            var topFlange = new Rectangle
            {
                Width = b,
                Height = s,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 1
            };
            Canvas.SetLeft(topFlange, centerX - b);
            Canvas.SetTop(topFlange, centerY - h / 2);
            _profileCanvas.Children.Add(topFlange);

            var bottomFlange = new Rectangle
            {
                Width = b,
                Height = s,
                Fill = Brushes.LightGray,
                Stroke = Brushes.Black,
                StrokeThickness = 1
            };
            Canvas.SetLeft(bottomFlange, centerX - b);
            Canvas.SetTop(bottomFlange, centerY + h / 2 - s);
            _profileCanvas.Children.Add(bottomFlange);

            // Одна выносная линия для высоты h
            AddSingleDimensionLine(centerX, centerY - h / 2, centerX, centerY + h / 2, "h", _profileHeight);
        }
