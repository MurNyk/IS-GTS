        }

        private void AddDimensions()
        {
            string dimensionText = "";

            if (_profileType == "Круглый")
            {
                dimensionText = $"⌀ = {_profileHeight:F1} мм";
            }
            else if (_profileType == "Квадратный")
            {
                dimensionText = $"a = {_profileHeight:F1} мм";
            }
            else if (_profileType == "Полосовой")
            {
                dimensionText = $"b = {_profileWidth:F1} мм\na = {_profileHeight:F1} мм";
            }
            else if (_profileType == "Уголок")
            {
                dimensionText = $"b = {_profileWidth:F1} мм\na = {_profileHeight:F1} мм";
            }
            else if (_profileType == "Швеллер")
            {
                dimensionText = $"h = {_profileHeight:F1} мм\nb = {_profileWidth:F1} мм\ns = {_webThickness:F1} мм";
            }
            else if (_profileType == "Двутавр")
            {
                dimensionText = $"h = {_profileHeight:F1} мм\nb = {_profileWidth:F1} мм\ns = {_webThickness:F1} мм\nt = {_flangeThickness:F1} мм";
            }
            else
            {
                dimensionText = $"h = {_profileHeight:F1} мм\nb = {_profileWidth:F1} мм";
            }

            var textBlock = new TextBlock
            {
                Text = dimensionText,
                FontSize = 10,
                Background = Brushes.White,
                Margin = new Thickness(5),
                Padding = new Thickness(3),
                Foreground = Brushes.Black
            };
            Canvas.SetRight(textBlock, 5);
            Canvas.SetBottom(textBlock, 5);
            _profileCanvas.Children.Add(textBlock);
        }
    }
