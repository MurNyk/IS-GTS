        private void LoadUserInfo()
        {
            try
            {
                if (App.CurrentUserID > 0)
                {
                    // ВАЖНО: НЕ используем using!
                    var context = DiplomMurEntities.GetContext();

                    // Отключаем ленивую загрузку для этого запроса
                    context.Configuration.LazyLoadingEnabled = false;

                    var user = context.User
                        .Include(u => u.Role)
                        .FirstOrDefault(u => u.UserID == App.CurrentUserID);

                    if (user != null)
                    {
                        // Сохраняем данные в локальные переменные
                        string fullName = $"{user.UserLastName} {user.UserFirstName} {user.UserPatronymic}".Trim();
                        string roleName = user.Role?.RoleName ?? "Пользователь";

                        // Обновляем UI
                        UserFioTextBlock.Text = fullName;
                        RoleTextBlock.Text = roleName;
                        UserImage.Source = new BitmapImage(new Uri("/Resources/UserAvatar.png", UriKind.Relative));
                    }

                    // Включаем обратно, если нужно где-то еще
                    context.Configuration.LazyLoadingEnabled = true;
                }
                else
                {
                    UserFioTextBlock.Text = "Гость";
                    RoleTextBlock.Text = "не авторизован";
                    UserImage.Source = new BitmapImage(new Uri("/Resources/guest_avatar.png", UriKind.Relative));
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Ошибка загрузки данных пользователя: {ex.Message}");
            }
        }

