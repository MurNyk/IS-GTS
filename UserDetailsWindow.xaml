        private void LoadMaterials()
        {
            var materials = Data.DiplomMurEntities.GetContext().Material
                .OrderBy(m=>m.MaterialName)
                .Select(m=>m.MaterialName)
                .ToList();

            MaterialComboBox.Items.Clear();
            MaterialComboBox.Items.Add("Все материалы");

            foreach (var material in materials)
            {
                MaterialComboBox.Items.Add(material);
            }
            MaterialComboBox.SelectedIndex = 0;
        }

        private void LoadCategories()
        {
            var categories = Data.DiplomMurEntities.GetContext().Category
                .OrderBy(c => c.CategorySortOrder)
                .Select(c => c.CategoryName)
                .ToList();

            TypeComboBox.Items.Clear();
            TypeComboBox.Items.Add("Все типы");

            foreach(var category in categories)
            {
                TypeComboBox.Items.Add(category);
            }
            TypeComboBox.SelectedIndex = 0;
        }

