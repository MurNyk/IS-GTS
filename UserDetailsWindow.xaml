        private void ShowWelcomeMessage()
        {
            RemoveCurrentMessage();
            ResultsDataGrid.Visibility = Visibility.Collapsed;

            var welcomeGrid = new Grid();

            var textBlock = new TextBlock
            {
                Text = "Выберите ГОСТ для начала работы",
                FontSize = 20,
                FontWeight = FontWeights.Light,
                HorizontalAlignment = HorizontalAlignment.Center,
                VerticalAlignment = VerticalAlignment.Center,
                TextAlignment = TextAlignment.Center,
                Foreground = Brushes.Gray
            };

            var subTextBlock = new TextBlock
            {
                Text = "Используйте фильтры выше для поиска нужного профиля",
                FontSize = 14,
                FontWeight = FontWeights.Light,
                HorizontalAlignment = HorizontalAlignment.Center,
                VerticalAlignment = VerticalAlignment.Center,
                TextAlignment = TextAlignment.Center,
                Foreground = Brushes.DarkGray,
                Margin = new Thickness(0, 60, 0, 0)
            };

            welcomeGrid.Children.Add(textBlock);
            welcomeGrid.Children.Add(subTextBlock);

            // СОХРАНЯЕМ ссылку на Border в поле!
            _currentMessageBorder = new Border
            {
                Child = welcomeGrid,
                Background = Brushes.White,
                BorderBrush = Brushes.LightGray, 
                BorderThickness = new Thickness(1),
                CornerRadius = new CornerRadius(8),
                Margin = new Thickness(20)
            };

            var mainGrid = ResultsDataGrid.Parent as Grid;
            if (mainGrid != null)
            {
                Grid.SetRow(_currentMessageBorder, 2);
                Grid.SetColumnSpan(_currentMessageBorder, 1);
                mainGrid.Children.Add(_currentMessageBorder);
            }
        }

        private void RemoveCurrentMessage()
        {
            if (_currentMessageBorder != null)
            {
                var mainGrid = ResultsDataGrid.Parent as Grid;
                if (mainGrid != null && mainGrid.Children.Contains(_currentMessageBorder))
                {
                    mainGrid.Children.Remove(_currentMessageBorder);
                }
                _currentMessageBorder = null;
            }
        }



