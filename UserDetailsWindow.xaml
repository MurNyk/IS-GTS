        private void Update()
        {
            try
            {
                var context = Data.DiplomMurEntities.GetContext();

                var query = context.Product
                    .Where(p => p.ProductIsActive == true)
                    .Include(p => p.Category)
                    .Include(p => p.Category.Material)
                    //.OrderBy(p=>p.ProductID)
                    .AsQueryable();

                string selectedMaterial = MaterialComboBox.SelectedItem?.ToString();
                if (selectedMaterial != "Все материалы" && !string.IsNullOrEmpty(selectedMaterial))
                {
                    query = query.Where(p => p.Category.Material.MaterialName == selectedMaterial);
                }
                string selectedCategory = TypeComboBox.SelectedItem?.ToString();
                if (selectedCategory != "Все типы" && !string.IsNullOrEmpty(selectedCategory))
                {
                    query = query.Where(p => p.Category.CategoryName == selectedCategory);
                }

                if (!string.IsNullOrWhiteSpace(SearchTextBox.Text))
                {
                    string searchText = SearchTextBox.Text.ToLower();
                    query = query.Where(p => p.ProductName.ToLower().Contains(searchText) ||
                    p.ProductStandartNumber.ToLower().Contains(searchText) ||
                    p.Category.Material.MaterialName.ToLower().Contains(searchText) ||
                    p.Category.CategoryName.ToLower().Contains(searchText));
                }

                var products = query
                    .Select(p => new ProductItem
                    {
                        ProductID = p.ProductID, // ДОБАВИТЬ ЭТУ СТРОКУ
                        Name = p.ProductName,
                        GostNumber = p.ProductStandartNumber,
                        Category = p.Category.CategoryName,
                        Material = p.Category.Material.MaterialName
                    })
                    .ToList();

                _filteredProducts = products;

                if (products.Count == 0)
                {
                    ShowNoResultsMessage();
                    ResultsCountText.Text = "Найдено: 0 профилей";
                }
                else
                {
                    ShowResultsInTable(products);
                    ResultsCountText.Text = $"Найдено: {products.Count} профилей";
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Ошибка поиска: {ex.Message}", "Ошибка", MessageBoxButton.OK, MessageBoxImage.Error);
            }
        }

        private void ShowResultsInTable(List<ProductItem> products)
        {
            RemoveCurrentMessage();
            ResultsDataGrid.Visibility = Visibility.Visible;
            ResultsDataGrid.Columns.Clear();

            var visibleColumns = _columnSettings.Where(c => c.IsVisible).ToList();

            for (int i = 0; i < visibleColumns.Count; i++)
            {
                var setting = visibleColumns[i];
                var column = new DataGridTextColumn
                {
                    Header = setting.DisplayName,
                    Binding = new System.Windows.Data.Binding(setting.FieldName),
                };

                // Если это последняя колонка - делаем занимает всё свободное место
                if (i == visibleColumns.Count - 1)
                {
                    column.Width = new DataGridLength(1, DataGridLengthUnitType.Star);
                }
                else
                {
                    column.Width = setting.Width;
                }

                ResultsDataGrid.Columns.Add(column);
            }

            ResultsDataGrid.ItemsSource = products;
        }

