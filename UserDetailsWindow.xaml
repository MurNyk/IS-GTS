        }

        private void Result_DoubleClick(object sender, MouseButtonEventArgs e)
        {
            var selectedProduct = ResultsDataGrid.SelectedItem as ProductItem;
            if (selectedProduct != null)
            {
                try
                {
                    // Запись в историю просмотров
                    if (App.CurrentUserID > 0)
                    {
                        using (var context = new Data.DiplomMurEntities())
                        {
                            var history = new Data.VisitHistory
                            {
                                VisitUserID = App.CurrentUserID,
                                VisitProductID = selectedProduct.ProductID,
                                VisitCreate = DateTime.Now,
                                VisitSearchQuery = SearchTextBox.Text
                            };
                            context.VisitHistory.Add(history);
                            context.SaveChanges();
                        }
                    }

                    var detailsWindow = new GostDetailsWindow(selectedProduct.GostNumber, App.CurrentUserID);
                    detailsWindow.Owner = this;
                    detailsWindow.ShowDialog();
                }
                catch (Exception ex)
                {
                    MessageBox.Show($"Ошибка при загрузке ГОСТа: {ex.Message}", "Ошибка");
                }
            }
        }



          
        

       

