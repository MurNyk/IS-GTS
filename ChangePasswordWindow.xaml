        private void LoadTemperatureConverters()
        {
            // Конвертация в Кельвины (базовая единица)
            _temperatureConvertersToBase = new Dictionary<string, Func<double, double>>
            {
                { "°C", (c) => c + 273.15 },
                { "°F", (f) => (f + 459.67) * 5.0 / 9.0 },
                { "K", (k) => k }
            };

            // Конвертация из Кельвинов
            _temperatureConvertersFromBase = new Dictionary<string, Func<double, double>>
            {
                { "°C", (k) => k - 273.15 },
                { "°F", (k) => k * 9.0 / 5.0 - 459.67 },
                { "K", (k) => k }
            };
        }

        private void CategoryComboBox_SelectionChanged(object sender, SelectionChangedEventArgs e)
        {
            if (CategoryComboBox.SelectedItem == null) return;

            string category = CategoryComboBox.SelectedItem.ToString();

            // Если выбрано "Выберите категорию" — очищаем
            if (category == "Выберите категорию")
            {
                IzValueComboBox.ItemsSource = null;
                VValueComboBox.ItemsSource = null;
                ClearAllDisplay();
                return;
            }

            // Загружаем единицы измерения
            List<string> units;
            if (category == "Температура")
            {
                units = _temperatureConvertersToBase.Keys.ToList();
            }
            else
            {
                units = _conversionRates[category].Keys.ToList();
            }

            // Добавляем "Выберите единицу" в начало списка
            var unitsWithPlaceholder = new List<string> { "Выберите единицу" };
            unitsWithPlaceholder.AddRange(units);

            IzValueComboBox.ItemsSource = unitsWithPlaceholder;
            VValueComboBox.ItemsSource = unitsWithPlaceholder;

            IzValueComboBox.SelectedIndex = 0;
            VValueComboBox.SelectedIndex = 0;

            ClearAllDisplay();
        }

        private void ValueTextBox_TextChanged(object sender, TextChangedEventArgs e)
        {
            // Игнорируем обновление, если текст - это плейсхолдер
            if (ValueTextBox.Text == "Введите число...")
                return;

            UpdateAll();
        }

        private void IzValueComboBox_SelectionChanged(object sender, SelectionChangedEventArgs e)
        {
            UpdateAll();
        }

        private void VValueComboBox_SelectionChanged(object sender, SelectionChangedEventArgs e)
        {
            UpdateAll();
        }

        private void UpdateResultText()
        {
            // Проверка ввода числа
            if (string.IsNullOrWhiteSpace(ValueTextBox.Text) || ValueTextBox.Text == "Введите число...")
            {
                ResultTextBlock.Text = "";
                return;
            }

            if (!double.TryParse(ValueTextBox.Text, out double value))
            {
                ResultTextBlock.Text = "";
                return;
            }

            string category = CategoryComboBox.SelectedItem.ToString();
            string fromUnit = IzValueComboBox.SelectedItem.ToString();
            string toUnit = VValueComboBox.SelectedItem.ToString();

            double result;

            try
            {
                if (category == "Температура")
                {
                    result = ConvertTemperature(value, fromUnit, toUnit);
                }
                else
                {
                    result = ConvertValue(value, category, fromUnit, toUnit);
                }
            }
            catch (Exception)
            {
                ResultTextBlock.Text = "";
                return;
            }

            string formattedResult = FormatResult(result);
            ResultTextBlock.Text = $"{value} {fromUnit} = {formattedResult} {toUnit}";
        }

        private double ConvertValue(double value, string category, string fromUnit, string toUnit)
        {
            var rates = _conversionRates[category];
            double valueInBase = value * rates[fromUnit];
            double result = valueInBase / rates[toUnit];
            return result;
        }

        private double ConvertTemperature(double value, string fromUnit, string toUnit)
        {
            double valueInKelvin = _temperatureConvertersToBase[fromUnit](value);
            double result = _temperatureConvertersFromBase[toUnit](valueInKelvin);
            return result;
        }

        private string FormatResult(double result)
        {
            if (double.IsInfinity(result) || double.IsNaN(result))
                return "Ошибка";

            // Целые числа (без дробной части)
            if (Math.Abs(result - Math.Round(result)) < 0.000001)
                return result.ToString("F0");

            // Для маленьких чисел — показываем до 6 знаков
            if (Math.Abs(result) < 0.01)
                return result.ToString("F6").TrimEnd('0').TrimEnd('.');

            // Обычные числа — 4 знака после запятой
            return result.ToString("F4").TrimEnd('0').TrimEnd('.');
        }

