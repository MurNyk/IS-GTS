    public partial class CalculatorWindow : Window
    {
        private Dictionary<string, Dictionary<string, double>> _conversionRates;
        private Dictionary<string, Func<double, double>> _temperatureConvertersToBase;
        private Dictionary<string, Func<double, double>> _temperatureConvertersFromBase;
        private Dictionary<string, string> _categoryDescriptions;

        public CalculatorWindow()
        {
            InitializeComponent();
            LoadCategoryDescriptions();
            LoadConverters();
            LoadTemperatureConverters();
            SetInitialComboBoxState();

            // Настройка плейсхолдера для TextBox
            SetupPlaceholder();

            // Принудительная подписка на событие TextChanged
            ValueTextBox.TextChanged += (s, e) => UpdateAll();

            // Также подписываем другие элементы
            CategoryComboBox.SelectionChanged += (s, e) => UpdateAll();
            IzValueComboBox.SelectionChanged += (s, e) => UpdateAll();
            VValueComboBox.SelectionChanged += (s, e) => UpdateAll();

            // Начальное состояние - пустые поля
            ClearAllDisplay();
        }

        private void SetupPlaceholder()
        {
            // Устанавливаем начальный текст-подсказку
            SetPlaceholderText();

            // Подписываемся на события
            ValueTextBox.GotFocus += RemovePlaceholder;
            ValueTextBox.LostFocus += SetPlaceholder;
        }

        private void SetPlaceholderText()
        {
            if (string.IsNullOrWhiteSpace(ValueTextBox.Text))
            {
                ValueTextBox.Text = "Введите число...";
                ValueTextBox.Foreground = Brushes.Gray;
                ValueTextBox.FontStyle = FontStyles.Italic;
                ValueTextBox.Background = Brushes.White;
            }
        }

        private void SetPlaceholder(object sender, RoutedEventArgs e)
        {
            if (string.IsNullOrWhiteSpace(ValueTextBox.Text))
            {
                ValueTextBox.Text = "Введите число...";
                ValueTextBox.Foreground = Brushes.Gray;
                ValueTextBox.FontStyle = FontStyles.Italic;
                ValueTextBox.Background = Brushes.White;
            }
        }

        private void RemovePlaceholder(object sender, RoutedEventArgs e)
        {
            if (ValueTextBox.Text == "Введите число...")
            {
                ValueTextBox.Text = "";
                ValueTextBox.Foreground = Brushes.Black;
                ValueTextBox.FontStyle = FontStyles.Normal;
                ValueTextBox.Background = Brushes.White;
            }
        }

        private void ClearAllDisplay()
        {
            ResultTextBlock.Text = "";
            DescriptionTextBlock.Text = "";
        }

        private void UpdateAll()
        {
            // Проверка: выбрана ли категория
            if (CategoryComboBox.SelectedItem == null ||
                CategoryComboBox.SelectedItem.ToString() == "Выберите категорию")
            {
                ClearAllDisplay();
                return;
            }

            // Проверка: выбраны ли единицы измерения
            if (IzValueComboBox.SelectedItem == null ||
                VValueComboBox.SelectedItem == null ||
                IzValueComboBox.SelectedItem.ToString() == "Выберите единицу" ||
                VValueComboBox.SelectedItem.ToString() == "Выберите единицу")
            {
                ClearAllDisplay();
                return;
            }

            // Обновляем описание
            string category = CategoryComboBox.SelectedItem.ToString();
            if (_categoryDescriptions.ContainsKey(category))
            {
                DescriptionTextBlock.Text = _categoryDescriptions[category];
            }

            // Обновляем результат
            UpdateResultText();
        }

        private void SetInitialComboBoxState()
        {
            // Категория: добавляем "Выберите категорию" и делаем его выбранным
            var categories = new List<string>
            {
                "Выберите категорию",
                "Длина",
                "Масса",
                "Площадь сечения",
                "Объем",
                "Статический момент",
                "Момент сопротивления",
                "Момент инерции",
                "Плотность",
                "Давление",
                "Сила",
                "Температура",
                "Скорость",
                "Время",
                "Угол",
                "Энергия",
                "Мощность"
            };

            CategoryComboBox.ItemsSource = categories;
            CategoryComboBox.SelectedIndex = 0;
            CategoryComboBox.SelectionChanged += CategoryComboBox_SelectionChanged;

            // Единицы измерения — пустые
            IzValueComboBox.ItemsSource = null;
            VValueComboBox.ItemsSource = null;
        }

